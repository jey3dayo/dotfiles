" Settings
set typelinkhints
let searchlimit = 30
let scrollstep = 70
let fullpagescrollpercent = 100
let barposition = "bottom"
let locale = "jp"
let mapleader = ","
let hintcharacters = "qwertyuiasdfghjklzxcvbnm"

" Search
command g tabnew google
let completionengines = ["google", "amazon"]
let searchalias g = "google"

" Ignore Site
let blacklists = ["https://inbox.google.com/*","*cloud.io/*","http://localhost/*"]

" Mapping
map h previousTab
map l nextTab
map b :buffer<Space>
map B :bookmarks<Space>
map d closeTab
map u lastClosedTab
map <M-i> goToInput
map @ pinTab
map <C-h> moveTabLeft
map <C-l> moveTabRight
map <M-r> reloadTabUncached

iunmapAll

" Code
" yank '%title% - %url%'
copyTitleUrl() -> {{
  RUNTIME('getRootUrl', function(url) {
    let ret = document.title + " - " + url;
    Clipboard.copy(ret);
    Status.setMessage(ret, 2);
  });
}}
map yY :call copyTitleUrl<CR>

map yy :call copyTitleUrl<CR>
