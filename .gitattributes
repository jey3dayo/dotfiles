# Auto-normalize line endings
* text=auto eol=lf

# Lock files (auto-generated, suppress diff, use ours on merge)
nvim/lazy-lock.json linguist-generated=true -diff merge=ours
Brewfile.lock.json linguist-generated=true -diff merge=ours

# Scripts and config files (force LF)
*.sh text eol=lf
*.nix text eol=lf
mise/tasks/*.toml text eol=lf

# Windows scripts (force CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
